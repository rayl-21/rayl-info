---
import Button from "../button.astro";
import PostsLoop from "../posts-loop.astro";
---

<section class="max-w-4xl mx-auto px-7 lg:px-0">
  <h2
    class="font-heading text-2xl font-bold leading-10 tracking-tight text-stone-900 dark:text-stone-100 mb-5"
    data-reveal
  >
    Latest Posts
  </h2>

  <div class="w-full max-w-4xl mx-auto my-7 xl:px-0">
    <div class="space-y-5">
      <PostsLoop count="5" />

      <div class="flex items-center justify-center w-full py-5">
        <Button text="View All Posts" link="/posts" />
      </div>
    </div>
  </div>
</section>
