---
import projects from "../../collections/projects.json";
import AdventureCard from "../adventure-card.astro";
import Button from "../button.astro";
import Project from "../project.astro";

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section class="max-w-4xl mx-auto px-7 lg:px-0">
  <h2
    class="font-display text-3xl font-bold leading-10 tracking-wider uppercase text-stone-900 dark:text-stone-100 mb-5 scroll-reveal"
  >
    Latest Adventures
  </h2>

  <div class="space-y-5">
    {featured.map((project) => (
      <AdventureCard project={project} />
    ))}

    {rest.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {rest.map((project) => (
          <Project
            name={project.name}
            description={project.tagline}
            url={project.url}
            image={project.image}
          />
        ))}
      </div>
    )}

    <div class="flex items-center justify-center w-full py-5">
      <Button text="View All My Adventures" link="/projects" />
    </div>
  </div>
</section>
