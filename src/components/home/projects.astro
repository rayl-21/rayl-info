---
import Button from "../button.astro";
---

<section class="max-w-7xl mx-auto px-7 lg:px-8 relative overflow-hidden">
  <!-- Minimal Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Subtle geometric pattern -->
    <div class="absolute top-20 left-10 w-24 h-24 border border-neutral-200 dark:border-neutral-800 rounded-full opacity-20"></div>
    <div class="absolute bottom-20 right-10 w-32 h-32 border border-neutral-200 dark:border-neutral-800 rounded-full opacity-10"></div>
  </div>

  <!-- Section Header -->
  <div class="relative z-10 text-center mb-16">
    <h2 class="text-2xl font-bold leading-10 tracking-tight text-neutral-900 dark:text-neutral-100 mb-6">
      Latest Adventures
    </h2>
    
    <p class="text-base text-neutral-600 dark:text-neutral-400 max-w-3xl mx-auto leading-relaxed">
      Journey through my recent creative endeavors and technical explorations. Click on any adventure to dive deeper into the story behind each project.
    </p>
  </div>

  <!-- Magic Adventure Grid - Empty for now -->
  <div 
    class="relative z-10"
    x-data="{ activeAdventure: null }"
  >
    <div class="text-center py-16">
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Coming soon... exciting adventures are being crafted! 
      </p>
    </div>
  </div>

  <!-- Call to Action -->
  <div class="relative z-10 flex items-center justify-center w-full mt-16 mb-8">
    <Button text="View All My Adventures" link="/projects" />
  </div>
</section>
